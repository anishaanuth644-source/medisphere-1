rules_version = '2';

// MediSphere Firestore security rules.
//
// Client-side RBAC (hiding sidebar items, disabling buttons) is purely a
// UX convenience — it is NOT security. These rules are the actual
// enforcement layer. Every collection below denies by default and only
// opens up the specific operations a role needs.
//
// Deploy with: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && currentUser().role == role && currentUser().active == true;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isAnyOf(roles) {
      return isSignedIn() && currentUser().active == true && (currentUser().role in roles);
    }

    // ---------- users ----------
    // Users can read/update their own profile (limited fields). Only
    // super_admin can create new user records (provisioning) or change roles.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
        (request.auth.uid == uid &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.active == resource.data.active);
      allow delete: if isSuperAdmin();
    }

    // ---------- employees & HR ----------
    match /employees/{id} {
      allow read: if isAnyOf(['super_admin', 'hr_manager']);
      allow write: if isAnyOf(['super_admin', 'hr_manager']);
    }

    match /attendance/{id} {
      allow read: if isAnyOf(['super_admin', 'hr_manager']);
      allow write: if isAnyOf(['super_admin', 'hr_manager']);
    }

    match /salary/{id} {
      allow read: if isAnyOf(['super_admin', 'hr_manager']);
      allow write: if isAnyOf(['super_admin', 'hr_manager']);
    }

    // ---------- doctors ----------
    match /doctors/{id} {
      // Broad read so receptionists/nurses can see availability when booking
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ---------- patients & clinical data ----------
    match /patients/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
      allow create: if isAnyOf(['super_admin', 'receptionist']);
      allow update: if isAnyOf(['super_admin', 'receptionist', 'nurse']);
      allow delete: if isSuperAdmin();
    }

    match /medical_records/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse']);
      allow create: if isAnyOf(['super_admin', 'doctor']);
      allow update: if isAnyOf(['super_admin', 'doctor']);
      allow delete: if isSuperAdmin();
    }

    match /prescriptions/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'pharmacist', 'nurse']);
      allow create: if isAnyOf(['super_admin', 'doctor']);
      allow update: if isAnyOf(['super_admin', 'doctor', 'pharmacist']);
      allow delete: if isSuperAdmin();
    }

    match /vaccinations/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse']);
      allow write: if isAnyOf(['super_admin', 'doctor', 'nurse']);
    }

    match /documents/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
      allow write: if isAnyOf(['super_admin', 'receptionist', 'doctor', 'nurse']);
    }

    // ---------- appointments ----------
    match /appointments/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
      allow create: if isAnyOf(['super_admin', 'receptionist']);
      allow update: if isAnyOf(['super_admin', 'receptionist', 'doctor', 'nurse']);
      allow delete: if isSuperAdmin();
    }

    // ---------- pharmacy & inventory ----------
    match /medicines/{id} {
      allow read: if isAnyOf(['super_admin', 'pharmacist', 'doctor']);
      allow write: if isAnyOf(['super_admin', 'pharmacist']);
    }

    match /stock/{id} {
      allow read: if isAnyOf(['super_admin', 'pharmacist']);
      // Stock ledger entries are append-only — no edits or deletes, even by admins,
      // to preserve a trustworthy inventory audit trail.
      allow create: if isAnyOf(['super_admin', 'pharmacist']);
      allow update, delete: if false;
    }

    match /pharmacy_sales/{id} {
      allow read: if isAnyOf(['super_admin', 'pharmacist']);
      allow create: if isAnyOf(['super_admin', 'pharmacist']);
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    match /suppliers/{id} {
      allow read: if isAnyOf(['super_admin', 'pharmacist']);
      allow write: if isAnyOf(['super_admin', 'pharmacist']);
    }

    // ---------- laboratory ----------
    match /lab_tests/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse']);
      allow write: if isAnyOf(['super_admin', 'doctor', 'nurse']);
    }

    // ---------- billing & insurance ----------
    match /billing/{id} {
      allow read: if isAnyOf(['super_admin', 'receptionist']);
      allow write: if isAnyOf(['super_admin', 'receptionist']);
    }

    match /insurance/{id} {
      allow read: if isAnyOf(['super_admin', 'receptionist']);
      allow write: if isAnyOf(['super_admin', 'receptionist']);
    }

    // ---------- admissions & rooms ----------
    match /admissions/{id} {
      allow read: if isAnyOf(['super_admin', 'receptionist', 'nurse']);
      allow write: if isAnyOf(['super_admin', 'receptionist', 'nurse']);
    }

    match /rooms/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyOf(['super_admin', 'receptionist', 'nurse']);
    }

    // ---------- emergency ----------
    match /emergency_cases/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
      allow write: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
    }

    match /ambulance/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor', 'nurse', 'receptionist']);
      allow write: if isAnyOf(['super_admin', 'receptionist', 'nurse']);
    }

    // ---------- notifications & feedback ----------
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // marking as read
      allow delete: if isSuperAdmin();
    }

    match /feedback/{id} {
      allow read: if isAnyOf(['super_admin', 'doctor']);
      // Feedback submission itself happens through a separate, unauthenticated
      // patient-facing flow (not covered by this admin app) — that flow should
      // use a Cloud Function with its own validation rather than direct writes.
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ---------- audit logs ----------
    // Append-only, super_admin read access only. No client ever updates or
    // deletes an audit entry — that defeats the purpose of an audit trail.
    match /audit_logs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
