# Copy this file to .env.local and fill in your Firebase project's web config.
# Found in: Firebase Console -> Project settings -> General -> Your apps -> SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to point the app at local Firebase emulators instead of
# production. Requires `firebase emulators:start` running separately.
VITE_USE_FIREBASE_EMULATORS=false

# Used only by scripts/seedFirestore.js (Node/Admin SDK script, not the app).
# Path to a service account JSON key downloaded from
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
